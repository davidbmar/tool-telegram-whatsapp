# Python bytecode
__pycache__/
*.pyc
*.pyo

# Packaging
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
env/
.env

# Testing / type-checking
.pytest_cache/
.mypy_cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Sprint ephemeral files
.agent-done-*
.sprint-test-output.txt
.sprint-timing.txt

# Terraform — never commit provider binaries or local state
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Node
node_modules/
